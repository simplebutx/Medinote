APP_NAME=Medicine Ai Server

# OpenAI-compatible LLM settings for chatbot answer generation.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30

# Upstage Solar embedding settings for Qdrant search.
UPSTAGE_API_KEY=
EMBEDDING_MODEL=solar-embedding-1-large-passage
EMBEDDING_QUERY_MODEL=solar-embedding-1-large-query
EMBEDDING_PASSAGE_MODEL=solar-embedding-1-large-passage
EMBEDDING_DIMENSIONS=4096

# OCR / Google Vision.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# S3 image loading.
AWS_S3_BUCKET=
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=

# Qdrant.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=medicine_docs

# Schedule database context.
SCHEDULE_DB_HOST=localhost
SCHEDULE_DB_PORT=3306
SCHEDULE_DB_NAME=medic
SCHEDULE_DB_USER=root
SCHEDULE_DB_PASSWORD=root
SCHEDULE_DB_CHARSET=utf8mb4

# Seed script options.
QDRANT_SEED_CSV_PATH=app/data/medicine_info_0531.csv
QDRANT_SEED_NAMES_FILE=app/data/demo_medicine_names_20.txt
QDRANT_SEED_SAMPLE_SIZE=10
QDRANT_SEED_RANDOM_SEED=42
QDRANT_SEED_SKIP_IF_NOT_EMPTY=true
QDRANT_SEED_CLEAR_COLLECTION=false
QDRANT_SEED_WAIT_TIMEOUT_SECONDS=60
